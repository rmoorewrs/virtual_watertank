---
services:
  watertank:
    image: docker.io/rmoorewrs/watertank:latest
    container_name: watertank
    ports:
    - 5050:5050
    volumes:
    - ./config:/config
  levelcontroller:
    image: docker.io/rmoorewrs/levelcontroller:latest
    container_name: levelcontroller
    ports:
    - 5051:5051
    volumes:
    - ./config:/config:watertank
